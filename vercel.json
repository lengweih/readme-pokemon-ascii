{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{tests/**,.venv/**,.pytest_cache/**,scripts/**,.vscode/**,.vercel/**}"
    }
  },
  "crons": [
    {
      "path": "/api/internal/prewarm",
      "schedule": "0 23 * * *"
    }
  ]
}
